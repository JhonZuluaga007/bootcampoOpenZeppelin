# Sepolia JSON-RPC endpoint (e.g. from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>

# Private key of the deployer/admin account (0x-prefixed). Use a dedicated
# testnet-only key — never a key that holds mainnet funds.
PRIVATE_KEY=0xabc123abc123abc123abc123abc123abc123abc123abc123abc123abc123ab

# Etherscan API key, used by `hardhat verify` to verify contracts on Sepolia
ETHERSCAN_API_KEY=ABC123ABC123ABC123ABC123ABC123ABC1
